# Copy this file to `.env` and fill in your own keys.
# The pipeline reads these at runtime; nothing here is committed to git.

# ── Required: legal data sources ──────────────────────────────────────
CANLII_KEY=your-canlii-api-key

# ── Required: OpenAI (used for summaries, Pass 1 scoring, and Pass 2) ─
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5-nano

# Optional tuning for the OpenAI client
OPENAI_MIN_INTERVAL=0.05
OPENAI_MAX_RETRIES=5

# ── Optional: Gemini (only used by run_dual_overnight.py) ─────────────
GEMINI_API_KEY=your-gemini-key

# ── Optional: PostgreSQL storage (only needed if --storage DB) ────────
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=postgres
DB_USER=your-username
DB_PASSWORD=your-password
DB_SSL=true

# ── Tuning knobs (safe defaults shown) ────────────────────────────────
SUMMARY_MAX_CHARS=60000
SUMMARY_CHUNK_CHARS=12000
